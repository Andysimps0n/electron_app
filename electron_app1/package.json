{
  "name": "electron_app1",
  "private": true,
  "version": "0.1.0",
  "description": "Vibe Focus — calendar, timer, and focus music desktop app",
  "author": "Vibe Focus",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:dist": "vite build && electron-builder --mac dmg --win nsis",
    "electron:dist:mac": "vite build && electron-builder --mac dmg",
    "electron:dist:win": "vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "express": "^5.2.1",
    "nodemon": "^3.1.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.vibefocus.app",
    "productName": "Vibe Focus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "icon": "src/assets/icon.png"
  }
}
